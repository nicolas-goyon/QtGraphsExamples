import QtQuick
import QtQuick.Layouts

Rectangle {
    Layout.fillWidth: true
    implicitHeight: inner.implicitHeight + 24
    color: "#181825"; radius: 8
    border.color: "#313244"; border.width: 1

    ColumnLayout {
        id: inner
        anchors { fill: parent; margins: 12 }
        spacing: 8

        Text { text: "About this example"; color: "#89b4fa"; font { pixelSize: 13; bold: true } }

        TextEdit {
            Layout.fillWidth: true
            readOnly: true; selectByMouse: true
            selectionColor: "#89b4fa"; selectedTextColor: "#1e1e2e"
            wrapMode: TextEdit.WordWrap
            text: "Shows the below-chart (side) legend pattern for a multi-series radar chart. A ColumnLayout stacks the chart Rectangle and a Row legend below it. The legend Row uses a Repeater over seriesNames to generate one swatch-and-label pair per series.\n\nThe seriesColors array is shared between the RadarChart series list and the legend Repeater, so adding or removing a series automatically updates both. The chart Rectangle takes Layout.fillHeight: true so it expands to fill the remaining vertical space above the legend strip."
            color: "#cdd6f4"; font.pixelSize: 12
        }

        Rectangle { Layout.fillWidth: true; height: 1; color: "#313244" }
        Text { text: "SOURCE FILES"; color: "#6c7086"; font { pixelSize: 10; bold: true; letterSpacing: 1 } }

        Column {
            Layout.fillWidth: true; spacing: 3
            Repeater {
                model: [
                    "qml/2d/radarchart/RadarChart.qml",
                    "qml/2d/radarchart/legend/RadarChartSideLegendExample.qml",
                    "qml/2d/radarchart/legend/RadarChartSideLegendDescription.qml"
                ]
                TextEdit {
                    width: parent.width; readOnly: true; selectByMouse: true
                    selectionColor: "#89b4fa"; selectedTextColor: "#1e1e2e"
                    text: "▸  " + modelData; color: "#a6e3a1"
                    font { pixelSize: 11; family: "Consolas" }
                }
            }
        }
    }
}
